# 生产环境配置模板
# 部署时复制为 .env 并填写 DATABASE、JWT_SECRET 后使用: cp .env.production.example .env

NODE_ENV=production
PORT=8888

# 必填：MongoDB 连接串
DATABASE=mongodb+srv://用户名:密码@cluster.xxx.mongodb.net/数据库名?retryWrites=true&w=majority

# 必填：JWT 密钥，请改为随机长字符串
JWT_SECRET=请替换为随机密钥

OPENSSL_CONF=/dev/null
PUBLIC_SERVER_FILE=https://app.olatech.ai/
# 多域名并存期 CSV 列出全部允许 origin（olajob.cn 迁移下架后可移除）
ALLOWED_ORIGINS=https://app.olatech.ai,https://app.olajob.cn

# 可选：邮件、AI、PDF
# RESEND_API=re_xxx
# GEMINI_API_KEY=your_gemini_key
# GOTENBERG_URL=http://box3-pdf:3000

# MCP server 绑定地址（分机部署时必填，同机可省略）
# 例：三箱拓扑中 NanoBot 在 Box2，MCP 要让 Box2 能通过 Tailscale 访问
# MCP_HOST=100.109.220.126
# MCP_SERVICE_TOKEN 必填（32 hex bytes，openssl rand -hex 32 生成）
# MCP_SERVICE_TOKEN=

# NanoBot（分机部署时 backend 连接 NanoBot 的地址）
# NANOBOT_HOST=box2-ai
# NANOBOT_PORT=8900
