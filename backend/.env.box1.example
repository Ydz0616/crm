# Box1 production env template — what `backend/.env` should contain on Box1
#
# IMPORTANT NAMING: docker-compose.yml on Box1 reads `backend/.env` (NOT
# `backend/.env.production` — there is no such file on Box1). This template
# documents the full key set that production needs; copy it into
# `backend/.env` on Box1 and fill in the canonical values from
# `.secrets/SERVERS.env` (single source of truth — see
# memory feedback_secrets_single_source_of_truth.md).
#
# Local dev does NOT need most of these — see `backend/.env.example`
# instead, which is the dev-only minimal subset (4 required keys).

NODE_ENV=production
PORT=8888

# Required: MongoDB connection string
DATABASE=mongodb+srv://username:password@cluster.xxx.mongodb.net/dbname?retryWrites=true&w=majority

# Required: JWT secret — generate with `openssl rand -hex 32`. Rotating this
# value invalidates all live admin sessions (users must re-login).
JWT_SECRET=replace_with_random_64_hex

# Required: Gemini API key. NanoBot's MCP layer renders this into
# ~/.nanobot/config.json on Box2 at provision time. Get from
# https://aistudio.google.com. Both Box1 backend and Box2 nanobot must
# use the SAME key value (otherwise you have two separate API quotas).
GEMINI_API_KEY=AIza...

# Required: CRM ↔ NanoBot loopback service token (generate: `openssl rand -hex 32`).
# Box1 backend's MCP server validates incoming Bearer; Box2 nanobot's
# config.json sends the SAME value. MISMATCH → MCP returns 401 and ALL
# tool calls silently fail → Ask Ola can chat but never invokes tools.
MCP_SERVICE_TOKEN=replace_with_32_hex_bytes

OPENSSL_CONF=/dev/null
PUBLIC_SERVER_FILE=https://app.olatech.ai/

# Production CORS allow-list (CSV). Add legacy domains during migration windows;
# remove after sunset.
ALLOWED_ORIGINS=https://app.olatech.ai,https://app.olajob.cn

# Optional: transactional email (Resend), PDF rendering (Gotenberg on Box3)
# RESEND_API=re_xxx
# GOTENBERG_URL=http://100.67.65.4:3000   # Box3 Tailscale IP

# Multi-box wiring — required when CRM is split across Box1/Box2/Box3.
# MCP_HOST is the bind address inside the docker-compose mcp container;
# MCP_BIND_ADDR (in project-root .env, NOT here) controls which host
# interface gets the port published.
MCP_HOST=100.109.220.126
NANOBOT_HOST=100.83.72.110
NANOBOT_PORT=8900
